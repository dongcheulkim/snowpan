generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  nickname      String?
  displayName   String   @default("name") // 'name' | 'nickname'
  phone         String   @unique
  phoneVerified Boolean  @default(false)
  profileImage  String?
  role          String   @default("user") // 'user' | 'admin'
  fcmToken      String?  // Firebase Cloud Messaging token
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products Product[]
  rentals  Rental[]
  lessons  Lesson[]
  accommodations Accommodation[]
  badgeRequests  BadgeRequest[]
  chatRoomsAsUser1 ChatRoom[] @relation("user1")
  chatRoomsAsUser2 ChatRoom[] @relation("user2")
  messages         Message[]
  notifications    Notification[]
  posts            Post[]
  comments         Comment[]
  postLikes        PostLike[]
  wishlists        Wishlist[]
  reviewsGiven     Review[]   @relation("reviewBuyer")
  reviewsReceived  Review[]   @relation("reviewSeller")
  reports          Report[]
  adRequests       AdRequest[]

  @@map("users")
}

model SkiResort {
  id        String   @id @default(uuid())
  name      String
  location  String
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rentals        Rental[]
  lessons        Lesson[]
  accommodations Accommodation[]

  @@map("ski_resorts")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  brand       String
  subcategory String?  // 'ski' | 'board' | 'boots' | 'binding' | 'helmet' | 'goggles' | 'wear' | 'etc'
  price       Int
  image       String
  images      String?  // 콤마 구분 여러 이미지 URL
  category    String   // 'new' | 'used'
  description String?
  rating      Float?
  reviewCount Int?
  condition   String?  // For used items: '상', '중', '하'
  usageCount  String?  // For used items
  status      String?  @default("selling") // 'selling' | 'reserved' | 'sold'
  isPremium   Boolean? @default(false)
  premiumUntil DateTime?
  bumpedAt    DateTime? @default(now())
  userId      String?  // null for admin-crawled items, set for user-submitted
  user        User?    @relation(fields: [userId], references: [id])
  wishlists   Wishlist[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([category, subcategory])
  @@index([category, createdAt])
  @@index([userId])
  @@index([createdAt])
  @@index([status])
  @@index([bumpedAt])
  @@map("products")
}

model Rental {
  id         String    @id @default(uuid())
  name       String
  price      Int
  duration   String
  equipment  String
  image      String
  resortId   String
  resort     SkiResort @relation(fields: [resortId], references: [id])
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  approved   Boolean   @default(false) // 관리자 승인 필요
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([resortId])
  @@index([userId])
  @@map("rentals")
}

model Lesson {
  id          String    @id @default(uuid())
  name        String
  price       Int
  duration    String
  level       String    // 'beginner' | 'intermediate' | 'advanced'
  maxStudents Int
  image       String
  resortId    String
  resort      SkiResort @relation(fields: [resortId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  approved    Boolean   @default(false) // 관리자 승인 필요
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([resortId])
  @@index([userId])
  @@map("lessons")
}

model Accommodation {
  id            String    @id @default(uuid())
  name          String
  type          String    // 'hotel' | 'pension' | 'condo' | 'minbak'
  price         Int
  originalPrice Int?
  guests        String    // '2인', '4인', '6인'
  features      String    // 콤마 구분
  image         String
  resortId      String
  resort        SkiResort @relation(fields: [resortId], references: [id])
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  approved      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([resortId])
  @@index([userId])
  @@map("accommodations")
}

model BadgeRequest {
  id        String   @id @default(uuid())
  badgeType String   // 'lv2' | 'lv3' | 'demo' | 'teaching' | 'pro'
  image     String?  // 자격증 사진 URL
  status    String   @default("pending") // 'pending' | 'approved' | 'rejected'
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("badge_requests")
}

model ChatRoom {
  id              String    @id @default(uuid())
  user1Id         String
  user1           User      @relation("user1", fields: [user1Id], references: [id])
  user2Id         String
  user2           User      @relation("user2", fields: [user2Id], references: [id])
  user1LastReadAt DateTime?
  user2LastReadAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  messages        Message[]

  @@unique([user1Id, user2Id])
  @@map("chat_rooms")
}

model Message {
  id        String   @id @default(uuid())
  content   String
  imageUrl  String?  // 이미지/동영상 URL (Cloudinary)
  type      String   @default("text") // 'text' | 'price_offer'
  roomId    String
  room      ChatRoom @relation(fields: [roomId], references: [id])
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  createdAt DateTime @default(now())

  @@index([roomId])
  @@index([senderId])
  @@map("messages")
}

model Post {
  id        String    @id @default(uuid())
  title     String
  content   String
  category  String    // 'free' | 'review' | 'resort' | 'tip' | 'carpool' | 'poll'
  sport     String    // 'ski' | 'board'
  images    String?   // 콤마 구분 이미지 URLs
  likes     Int       @default(0)
  views     Int       @default(0)
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  comments  Comment[]
  postLikes PostLike[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([sport])
  @@index([category])
  @@index([userId])
  @@index([createdAt])
  @@map("posts")
}

model PostLike {
  id     String @id @default(uuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@map("post_likes")
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlists")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@map("comments")
}

model Notification {
  id        String   @id @default(uuid())
  type      String   // 'chat' | 'approve' | 'reject' | 'system' | 'badge'
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@map("notifications")
}

model PhoneVerification {
  id        String   @id @default(uuid())
  phone     String
  code      String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("phone_verifications")
}

model Review {
  id        String   @id @default(uuid())
  rating    Int      // 1-5
  content   String
  sellerId  String
  seller    User     @relation("reviewSeller", fields: [sellerId], references: [id])
  buyerId   String
  buyer     User     @relation("reviewBuyer", fields: [buyerId], references: [id])
  productId String?
  createdAt DateTime @default(now())

  @@index([sellerId])
  @@index([buyerId])
  @@map("reviews")
}

model Report {
  id          String   @id @default(uuid())
  type        String   // 'product' | 'post' | 'user'
  targetId    String
  reason      String
  description String?
  reporterId  String
  reporter    User     @relation(fields: [reporterId], references: [id])
  status      String   @default("pending") // 'pending' | 'resolved'
  createdAt   DateTime @default(now())

  @@index([reporterId])
  @@index([type, targetId])
  @@map("reports")
}

model Banner {
  id          String   @id @default(uuid())
  title       String
  description String
  tag         String
  url         String
  image       String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("banners")
}

model AdRequest {
  id          String   @id @default(uuid())
  type        String   // 'main_banner' | 'category'
  category    String?  // 'used' | 'rental' | 'lesson' | 'accommodation' | null
  title       String
  description String
  url         String
  image       String?
  message     String?  // 광고주 추가 메모
  status      String   @default("pending") // 'pending' | 'approved' | 'rejected'
  adminNote   String?  // 거부 사유 등
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("ad_requests")
}
