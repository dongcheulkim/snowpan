generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  nickname      String?
  displayName   String   @default("name") // 'name' | 'nickname'
  phone         String   @unique
  phoneVerified Boolean  @default(false)
  profileImage  String?
  role          String   @default("user") // 'user' | 'admin'
  activeBadge   String?  // 노출할 뱃지 1개 (null이면 숨김)
  fcmToken      String?  // Firebase Cloud Messaging token
  points        Int      @default(0) // 캐시된 포인트 잔액. 진실은 PointTransaction 누적합 — 트랜잭션 안에서만 갱신.
  // 쿠폰 효과 — 기간제. 만료 시각 지나면 효과 없음.
  referralBoostUntil  DateTime? // 초대 2배 쿠폰: 이 시각까지 추천 보너스 2배
  profileHighlightUntil DateTime? // 프로필 강조 쿠폰: 이 시각까지 프로필/이름 강조
  referralCode  String?  @unique // 본인의 추천 코드 (lazy 생성)
  referredById  String?  // 누구의 추천으로 가입했는지
  referredBy    User?    @relation("referrals", fields: [referredById], references: [id])
  referrals     User[]   @relation("referrals")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products Product[]
  rentals  Rental[]
  lessons  Lesson[]
  accommodations Accommodation[]
  badgeRequests  BadgeRequest[]
  chatRoomsAsUser1 ChatRoom[] @relation("user1")
  chatRoomsAsUser2 ChatRoom[] @relation("user2")
  messages         Message[]
  notifications    Notification[]
  posts            Post[]
  comments         Comment[]
  postLikes        PostLike[]
  wishlists        Wishlist[]
  reviewsGiven     Review[]   @relation("reviewBuyer")
  reviewsReceived  Review[]   @relation("reviewSeller")
  reports          Report[]
  adRequests       AdRequest[]
  adBookings       AdBooking[]
  skiShops         SkiShop[]
  repairShops      RepairShop[]
  pointTransactions PointTransaction[]
  userCoupons      UserCoupon[]
  snowRuns         SnowRun[]
  adViews          AdView[]
  shopPosts        ShopPost[]
  polls            Poll[]

  @@map("users")
}

// 보상형 광고 시청 기록 — 쿠폰 구매 시 최근 5분 내 미사용 시청 기록이 있어야 통과.
// source: 'admob' (앱 보상형) | 'web_inhouse' (자체 노출) | 'test'.
model AdView {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  source      String
  platform    String   // 'ios' | 'android' | 'web'
  purpose     String   @default("coupon_purchase") // 어디서 쓰려고 시청했는지
  consumed    Boolean  @default(false) // 구매 시 true 로 마킹
  consumedAt  DateTime?
  viewedAt    DateTime @default(now())

  @@index([userId, consumed, viewedAt])
  @@map("ad_views")
}

// 스노우런 1회 = 슬로프 한 번 내려옴. GPS 클라이언트가 측정해 서버에 제출.
// 서버는 거리/낙차/시간이 합리적 범위 안에 있을 때만 validated=true + 포인트 지급.
// 부정 사용(차/케이블카/가짜 GPS)은 차후 폴리곤 매칭으로 검증 강화 예정.
model SnowRun {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  startedAt     DateTime
  endedAt       DateTime
  durationSec   Int      // 끝 - 시작 (초)
  distanceM     Int      // 누적 수평 거리 (m)
  verticalDropM Int      // 누적 낙차 (m) — 음의 고도 변화 합
  maxSpeedKmh   Float?   // 최고 속도 (km/h)
  avgSpeedKmh   Float?   // 평균 속도 (km/h)
  resortId      String?  // 리조트 매칭 (Phase 1 폴리곤 매칭 후)
  source        String   @default("web_gps") // 'web_gps' | 'app_gps' | 'manual'
  validated     Boolean  @default(false) // 검증 통과 → 포인트 지급
  pointsAwarded Int      @default(0)
  // 지도 표시용 전체 GPS 경로. 형식: [{lat, lng, alt?, t?}, ...]
  // ~1800포인트 (30분) ≈ 50KB. PostgreSQL JSONB.
  trackJson     Json?
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@map("snow_runs")
}

// 포인트 적립/사용 이력. 모든 변화를 감사 가능하도록 기록.
// 잔액 변경은 반드시 prisma.$transaction 안에서 User.points 와 함께 갱신.
model PointTransaction {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  amount       Int      // +적립, -사용
  balanceAfter Int      // 거래 직후 잔액 (감사용 — User.points 와 비교해 정합성 확인 가능)
  source       String   // 'signup_bonus' | 'referral_bonus' | 'snow_run' | 'review' | 'daily_checkin' | 'coupon_purchase' | 'admin_grant' | 'admin_deduct' | 'expire'
  refId        String?  // 관련 엔티티 id (쿠폰구매면 UserCoupon.id, 런이면 SnowRun.id 등)
  description  String?  // 노출용 설명 ("회원가입 축하 보너스", "쿠폰 구매: 렌탈 10% 할인")
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, source, createdAt]) // 일일 출석체크 idempotency 조회 최적화
  @@map("point_transactions")
}

// 쿠폰 카탈로그 — 운영자가 발행. partnerId 가 null 이면 스노우판 자체 쿠폰.
model Coupon {
  id            String   @id @default(uuid())
  title         String   // "스키 렌탈 10% 할인"
  description   String?
  pointsCost    Int      // 필요 포인트
  partnerType   String   // 'rental' | 'lesson' | 'skishop' | 'accommodation' | 'repair' | 'general' | 'platform'
  partnerId     String?  // 특정 매장 한정이면 그 매장 id
  discountType  String   // 'percent' | 'flat' | 'none'  (platform 효과형은 'none')
  discountValue Int      // percent=10 → 10%, flat=10000 → 10,000원 할인, none 이면 0
  // 플랫폼 자체 발급 쿠폰 효과. null 이면 파트너 발급 (오프라인 사용).
  // 'product_bump' = 매물 끌어올리기 (bumpedAt=now), effectValue 만큼 사용 가능 횟수.
  effect        String?
  effectValue   Int?
  image         String?
  validDays     Int      @default(30) // 구매 후 N일 동안 사용 가능
  stock         Int?     // null = 무제한, 0 이면 매진
  active        Boolean  @default(true)
  vertical      String   @default("snow")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userCoupons  UserCoupon[]

  @@index([vertical, active])
  @@index([vertical, active, partnerType]) // 쿠폰샵 partnerType 필터 조회 최적화
  @@map("coupons")
}

// 사용자가 포인트로 구매한 쿠폰. code 는 매장에서 사용 확인용.
model UserCoupon {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  couponId    String
  coupon      Coupon   @relation(fields: [couponId], references: [id])
  code        String   @unique // 8자리 영숫자 — 매장 확인용
  status      String   @default("active") // 'active' | 'used' | 'expired'
  // 다회권 (예: 끌어올리기 5회 묶음) 남은 횟수. 단회 쿠폰은 1, 5회 묶음은 5 로 시작.
  // 0 이 되면 status='used'.
  usesLeft    Int      @default(1)
  expiresAt   DateTime
  usedAt      DateTime?
  purchasedAt DateTime @default(now())

  @@index([userId, status])
  @@map("user_coupons")
}

model SkiResort {
  id        String   @id @default(uuid())
  name      String
  location  String
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rentals        Rental[]
  lessons        Lesson[]
  accommodations Accommodation[]

  @@map("ski_resorts")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  brand       String
  subcategory String?  // 'ski' | 'board' | 'boots' | 'binding' | 'helmet' | 'goggles' | 'wear' | 'etc'
  price       Int
  image       String
  images      String?  // 콤마 구분 여러 이미지 URL
  category    String   // 'new' | 'used'
  description String?
  rating      Float?
  reviewCount Int?
  viewCount   Int      @default(0) // 상세 페이지 조회수
  condition   String?  // For used items: '상', '중', '하'
  usageCount  String?  // For used items
  length      String?  // 길이 (cm) - 스키/보드
  radius      String?  // 회전반경 (m) - 스키
  flex        String?  // 플렉스 - 부츠/보드
  size        String?  // 사이즈 - 부츠/바인딩/헬멧/의류
  status      String?  @default("selling") // 'selling' | 'reserved' | 'sold'
  isPremium   Boolean? @default(false)
  premiumUntil DateTime?
  bumpedAt    DateTime? @default(now())
  userId      String?  // null for admin-crawled items, set for user-submitted
  user        User?    @relation(fields: [userId], references: [id])
  wishlists   Wishlist[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vertical    String   @default("snow") // 'snow' | 'bike' | 'run' | 'surf' | 'golf' | 'camp'

  @@index([category])
  @@index([category, subcategory])
  @@index([category, createdAt])
  @@index([userId])
  @@index([createdAt])
  @@index([status])
  @@index([bumpedAt])
  @@index([brand])
  @@index([category, subcategory, brand])
  @@index([vertical, category, createdAt]) // 플랫폼별 최신 매물
  @@index([vertical, category, subcategory]) // 플랫폼별 카테고리 필터
  @@map("products")
}

model Rental {
  id                    String    @id @default(uuid())
  name                  String
  price                 Int
  duration              String
  equipment             String
  image                 String
  businessLicense       String?   // 사업자등록증 이미지 URL
  resortId              String
  resort                SkiResort @relation(fields: [resortId], references: [id], onDelete: Cascade)
  userId                String
  user                  User      @relation(fields: [userId], references: [id])
  approved              Boolean   @default(false) // 관리자 승인 필요
  vertical              String    @default("snow")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([resortId])
  @@index([userId])
  @@index([approved, createdAt]) // 승인된 매물 최신순 목록
  @@index([vertical, approved, createdAt])
  @@map("rentals")
}

model Lesson {
  id                    String    @id @default(uuid())
  name                  String
  price                 Int
  duration              String
  level                 String    // 'beginner' | 'intermediate' | 'advanced'
  maxStudents           Int
  image                 String
  instructorCert        String?   // 강사 자격증 이미지 URL
  businessLicense       String?   // 사업자등록증 이미지 URL
  resortId              String
  resort                SkiResort @relation(fields: [resortId], references: [id], onDelete: Cascade)
  userId                String
  user                  User      @relation(fields: [userId], references: [id])
  approved              Boolean   @default(false) // 관리자 승인 필요
  vertical              String    @default("snow")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([resortId])
  @@index([userId])
  @@index([approved, createdAt])
  @@index([vertical, approved, createdAt])
  @@map("lessons")
}

model Accommodation {
  id                    String    @id @default(uuid())
  name                  String
  type                  String    // 'hotel' | 'pension' | 'condo' | 'minbak'
  price                 Int
  originalPrice         Int?
  guests                String    // '2인', '4인', '6인'
  features              String    // 콤마 구분
  image                 String
  businessLicense       String?   // 사업자등록증 이미지 URL (필수)
  accommodationPermit   String?   // 숙박업 신고증 이미지 URL
  resortId              String
  resort                SkiResort @relation(fields: [resortId], references: [id], onDelete: Cascade)
  userId                String
  user                  User      @relation(fields: [userId], references: [id])
  approved              Boolean   @default(false)
  vertical              String    @default("snow")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([resortId])
  @@index([userId])
  @@index([approved, createdAt])
  @@index([vertical, approved, createdAt])
  @@map("accommodations")
}

model BadgeRequest {
  id        String   @id @default(uuid())
  vertical  String   @default("snow") // 'snow' | 'bike' | 'run' | 'surf' | 'golf' | 'camp' — 종목별 전문성
  badgeType String   // vertical 안에서 해석: snow.lv1, bike.coach, run.marathoner 등
  image     String?  // 자격증 사진 URL
  status    String   @default("pending") // 'pending' | 'approved' | 'rejected'
  priority  Boolean  @default(false) // 뱃지 신속처리 쿠폰: 승인 대기열 상단 노출
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt]) // 관리자 승인 대기 목록
  @@index([userId])             // 내 뱃지 요청 조회
  @@index([userId, vertical])   // 특정 vertical 내 뱃지 조회 (UserBadges 필터링)
  @@map("badge_requests")
}

model ChatRoom {
  id              String    @id @default(uuid())
  user1Id         String
  user1           User      @relation("user1", fields: [user1Id], references: [id])
  user2Id         String
  user2           User      @relation("user2", fields: [user2Id], references: [id])
  user1LastReadAt DateTime?
  user2LastReadAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  messages        Message[]

  @@unique([user1Id, user2Id])
  @@map("chat_rooms")
}

model Message {
  id        String   @id @default(uuid())
  content   String
  imageUrl  String?  // 이미지/동영상 URL (Cloudinary)
  type      String   @default("text") // 'text' | 'price_offer'
  roomId    String
  room      ChatRoom @relation(fields: [roomId], references: [id])
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  createdAt DateTime @default(now())

  @@index([roomId])
  @@index([senderId])
  @@index([roomId, createdAt]) // 채팅방 메시지 페이지네이션
  @@map("messages")
}

model Post {
  id        String    @id @default(uuid())
  title     String
  content   String
  category  String    // 'free' | 'review' | 'resort' | 'tip' | 'carpool' | 'meetup' | 'poll'
  sport     String    // snow: 'ski' | 'board' / bike: 'road' | 'mtb' / etc.
  vertical  String    @default("snow")
  images    String?   // 콤마 구분 이미지 URLs
  likes     Int       @default(0)
  views     Int       @default(0)
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  comments  Comment[]
  postLikes PostLike[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([sport])
  @@index([category])
  @@index([userId])
  @@index([createdAt])
  @@index([sport, createdAt])
  @@index([sport, category, createdAt])
  @@index([vertical, createdAt]) // 플랫폼별 최신순 커뮤니티
  @@index([vertical, category, createdAt])
  @@map("posts")
}

model PostLike {
  id     String @id @default(uuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@map("post_likes")
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlists")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
  @@index([userId])
  @@map("comments")
}

model Notification {
  id        String   @id @default(uuid())
  type      String   // 'chat' | 'approve' | 'reject' | 'system' | 'badge'
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId, createdAt]) // /api/notifications 최신순 조회
  @@index([userId, read])      // 미읽음 카운트
  @@map("notifications")
}

model PhoneVerification {
  id        String   @id @default(uuid())
  phone     String
  code      String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("phone_verifications")
}

model EmailVerification {
  id        String   @id @default(uuid())
  email     String
  code      String
  purpose   String   @default("password_reset") // 'password_reset' | 'email_change' 등
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, code])
  @@map("email_verifications")
}

// 일일 방문 집계 — IP 단위로 하루 한 row, count 증가시켜 페이지뷰 누적.
// 관리자 통계 (DAU, 일별 방문자 추이, 페이지뷰) 의 데이터 소스.
model DailyVisit {
  id        String   @id @default(uuid())
  ip        String
  userId    String?  // 로그인한 유저면 기록
  date      String   // YYYY-MM-DD (KST 기준)
  count     Int      @default(1)
  firstSeen DateTime @default(now())
  lastSeen  DateTime @default(now())

  @@unique([ip, date])
  @@index([date])
  @@map("daily_visits")
}

model Review {
  id        String   @id @default(uuid())
  rating    Int      // 1-5
  content   String
  sellerId  String
  seller    User     @relation("reviewSeller", fields: [sellerId], references: [id])
  buyerId   String
  buyer     User     @relation("reviewBuyer", fields: [buyerId], references: [id])
  productId String?
  createdAt DateTime @default(now())

  @@index([sellerId])
  @@index([buyerId])
  @@index([sellerId, createdAt]) // 판매자 리뷰 최신순
  @@map("reviews")
}

model Report {
  id          String   @id @default(uuid())
  type        String   // 'product' | 'post' | 'user'
  targetId    String
  reason      String
  description String?
  reporterId  String
  reporter    User     @relation(fields: [reporterId], references: [id])
  status      String   @default("pending") // 'pending' | 'resolved'
  createdAt   DateTime @default(now())

  @@index([reporterId])
  @@index([type, targetId])
  @@map("reports")
}

model Banner {
  id          String   @id @default(uuid())
  title       String
  description String
  tag         String
  url         String
  image       String?
  textColor   String?  // 글자 색상 hex (#ffffff)
  textAlign   String?  // 글자 위치 'left' | 'center' | 'right'
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("banners")
}

model AdSlotPricing {
  id            String   @id @default(uuid())
  slotType      String   // 'main_banner' | 'category' | 'premium'
  category      String   @default("none") // 'none' | 'used' | 'rental' | 'lesson' | 'accommodation'
  pricePerDay   Int      // 1일 가격 (원)
  maxConcurrent Int      @default(1) // 동시 광고 가능 수
  description   String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bookings AdBooking[]

  @@unique([slotType, category])
  @@map("ad_slot_pricings")
}

model AdBooking {
  id          String   @id @default(uuid())
  slotType    String   // 'main_banner' | 'category' | 'premium'
  category    String   @default("none") // 'none' | 'used' | 'rental' | 'lesson' | 'accommodation'
  title       String
  description String
  url         String
  image       String?
  textColor   String?  // 글자 색상 hex (#ffffff)
  textAlign   String?  // 글자 위치 'left' | 'center' | 'right'
  startDate   DateTime
  endDate     DateTime
  totalDays   Int
  totalPrice  Int
  status      String   @default("pending_payment")
  // 'pending_payment' | 'paid' | 'active' | 'completed' | 'cancelled' | 'refunded'
  adminNote   String?

  userId    String
  user      User          @relation(fields: [userId], references: [id])
  pricingId String
  pricing   AdSlotPricing @relation(fields: [pricingId], references: [id])
  payment   AdPayment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([slotType, startDate, endDate])
  @@index([startDate])
  @@index([endDate])
  @@map("ad_bookings")
}

model AdPayment {
  id           String    @id @default(uuid())
  bookingId    String    @unique
  booking      AdBooking @relation(fields: [bookingId], references: [id])
  paymentId    String    @unique // PortOne payment ID
  merchantUid  String    @unique // 주문번호
  payMethod    String    // 'card' | 'tosspay' | 'kakaopay' | 'naverpay'
  amount       Int
  status       String    @default("paid") // 'paid' | 'cancelled' | 'refunded'
  paidAt       DateTime
  receiptUrl   String?
  pgProvider   String?
  pgTid        String?
  cancelledAt  DateTime?
  cancelReason String?
  refundAmount Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ad_payments")
}

model AdRequest {
  id          String   @id @default(uuid())
  type        String   // 'main_banner' | 'category'
  category    String?  // 'used' | 'rental' | 'lesson' | 'accommodation' | null
  title       String
  description String
  url         String
  image       String?
  message     String?  // 광고주 추가 메모
  status      String   @default("pending") // 'pending' | 'approved' | 'rejected'
  adminNote   String?  // 거부 사유 등
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("ad_requests")
}

model SkiShop {
  id              String   @id @default(uuid())
  name            String
  area            String   // '강원' | '경기' | '서울' 등
  resort          String?  // 소속 스키장
  address         String
  description     String
  brands          String?  // 콤마 구분 브랜드
  phone           String?
  instagram       String?
  website         String?
  naverMap        String?
  hours           String?  // 영업시간
  image           String?  // 샵 대표 이미지
  businessLicense String   // 사업자등록증 이미지 (필수)
  approved        Boolean  @default(false)
  isPremium       Boolean  @default(false)
  premiumUntil    DateTime?
  vertical        String   @default("snow")
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([area])
  @@index([approved])
  @@index([approved, isPremium, createdAt])
  @@index([vertical, approved, isPremium, createdAt])
  @@map("ski_shops")
}

model RepairShop {
  id              String   @id @default(uuid())
  name            String
  area            String
  address         String
  description     String
  services        String?  // 콤마 구분 (튜닝, 왁싱, 바인딩, 엣지 등)
  phone           String?
  instagram       String?
  website         String?
  naverMap        String?
  hours           String?
  image           String?
  businessLicense String
  approved        Boolean  @default(false)
  isPremium       Boolean  @default(false)
  premiumUntil    DateTime?
  vertical        String   @default("snow")
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([area])
  @@index([approved])
  @@index([approved, isPremium, createdAt])
  @@index([vertical, approved, isPremium, createdAt])
  @@map("repair_shops")
}

// 실시간 웹캠 — 리조트 메타 + 카메라 스트림 URL.
// 시즌별로 스트림 URL 이 자주 바뀌고 새 리조트 추가될 수 있어 DB 화.
model Webcam {
  id          String   @id @default(uuid())
  slug        String   @unique // 'yongpyong'
  name        String   // '용평리조트'
  region      String   // '강원'
  slopes      Int      @default(0)
  elevation   String?  // '1,458m'
  camCount    Int      @default(0)
  cameras     Json?    // [{ label, stream }] — JSON 배열
  externalUrl String?  // 스트림 없을 때 공식 사이트
  active      Boolean  @default(true)
  order       Int      @default(0)
  vertical    String   @default("snow") // snow=리조트, surf=라인업, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, order])
  @@index([vertical, active, order])
  @@map("webcams")
}

// 미출시 5종목 (bike/run/surf/golf/camp) 사전 가입 — Coming Soon 페이지에서 수집.
// 마케팅 자산: 출시 시 알림 발송, 관심 기능 분석에 활용.
model PreRegister {
  id                 String   @id @default(uuid())
  email              String
  name               String?
  sport              String   // bike, run, surf, golf, camp
  interestedFeatures Json     @default("[]") // 선택한 기능 라벨 배열
  ip                 String?  // rate-limit / abuse 추적용
  userAgent          String?  // 디버깅·중복 감지 보조
  createdAt          DateTime @default(now())

  @@unique([email, sport])
  @@index([sport, createdAt])
  @@map("pre_registers")
}

// 매장 소식(포스트) — 스키샵/정비/렌탈/레슨/숙소 매니저가 매장 상세 페이지에 올리는
// 자체 홍보 콘텐츠. 인스타/블로그 스타일. 여러 사진 + 자유 텍스트.
// polymorphic ref (shopType + shopId) — 모델 통합 관리 편의성 우선.
model ShopPost {
  id         String   @id @default(uuid())
  shopType   String   // 'skishop' | 'repair' | 'rental' | 'lesson' | 'accommodation'
  shopId     String   // 각 shop 테이블의 id
  userId     String   // 작성자 (shop 소유자만 가능)
  user       User     @relation(fields: [userId], references: [id])
  title      String
  content    String   @db.Text
  images     String?  // 콤마 구분 이미지 URL (최대 5장)
  postType   String   @default("general") // 'promo' | 'notice' | 'event' | 'general'
  pinned     Boolean  @default(false)
  viewCount  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([shopType, shopId, pinned, createdAt])
  @@index([userId, createdAt])
  @@map("shop_posts")
}

// 투표 — 커뮤니티 투표 기능. 이전엔 100% localStorage 라 유저 간 공유 안 되고
// 조작 가능했음. 서버화: 1인 1표 (PollVote unique) 강제, 집계 서버 계산.
model Poll {
  id        String       @id @default(uuid())
  title     String
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  options   PollOption[]
  votes     PollVote[]
  likes     Int          @default(0)
  views     Int          @default(0)
  vertical  String       @default("snow")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([vertical, createdAt])
  @@map("polls")
}

model PollOption {
  id     String     @id @default(uuid())
  pollId String
  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  label  String
  order  Int        @default(0)
  votes  PollVote[]

  @@index([pollId, order])
  @@map("poll_options")
}

model PollVote {
  id       String     @id @default(uuid())
  pollId   String
  poll     Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId String
  option   PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId   String
  createdAt DateTime  @default(now())

  @@unique([pollId, userId]) // 1인 1표
  @@index([optionId])
  @@map("poll_votes")
}
