generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  nickname      String?
  displayName   String   @default("name") // 'name' | 'nickname'
  phone         String   @unique
  phoneVerified Boolean  @default(false)
  profileImage  String?
  role          String   @default("user") // 'user' | 'admin'
  activeBadge   String?  // 노출할 뱃지 1개 (null이면 숨김)
  fcmToken      String?  // Firebase Cloud Messaging token
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products Product[]
  rentals  Rental[]
  lessons  Lesson[]
  accommodations Accommodation[]
  badgeRequests  BadgeRequest[]
  chatRoomsAsUser1 ChatRoom[] @relation("user1")
  chatRoomsAsUser2 ChatRoom[] @relation("user2")
  messages         Message[]
  notifications    Notification[]
  posts            Post[]
  comments         Comment[]
  postLikes        PostLike[]
  wishlists        Wishlist[]
  reviewsGiven     Review[]   @relation("reviewBuyer")
  reviewsReceived  Review[]   @relation("reviewSeller")
  reports          Report[]
  adRequests       AdRequest[]
  adBookings       AdBooking[]
  skiShops         SkiShop[]
  repairShops      RepairShop[]

  @@map("users")
}

model SkiResort {
  id        String   @id @default(uuid())
  name      String
  location  String
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rentals        Rental[]
  lessons        Lesson[]
  accommodations Accommodation[]

  @@map("ski_resorts")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  brand       String
  subcategory String?  // 'ski' | 'board' | 'boots' | 'binding' | 'helmet' | 'goggles' | 'wear' | 'etc'
  price       Int
  image       String
  images      String?  // 콤마 구분 여러 이미지 URL
  category    String   // 'new' | 'used'
  description String?
  rating      Float?
  reviewCount Int?
  condition   String?  // For used items: '상', '중', '하'
  usageCount  String?  // For used items
  length      String?  // 길이 (cm) - 스키/보드
  radius      String?  // 회전반경 (m) - 스키
  flex        String?  // 플렉스 - 부츠/보드
  size        String?  // 사이즈 - 부츠/바인딩/헬멧/의류
  status      String?  @default("selling") // 'selling' | 'reserved' | 'sold'
  isPremium   Boolean? @default(false)
  premiumUntil DateTime?
  bumpedAt    DateTime? @default(now())
  userId      String?  // null for admin-crawled items, set for user-submitted
  user        User?    @relation(fields: [userId], references: [id])
  wishlists   Wishlist[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([category, subcategory])
  @@index([category, createdAt])
  @@index([userId])
  @@index([createdAt])
  @@index([status])
  @@index([bumpedAt])
  @@map("products")
}

model Rental {
  id                    String    @id @default(uuid())
  name                  String
  price                 Int
  duration              String
  equipment             String
  image                 String
  businessLicense       String?   // 사업자등록증 이미지 URL
  resortId              String
  resort                SkiResort @relation(fields: [resortId], references: [id], onDelete: Cascade)
  userId                String
  user                  User      @relation(fields: [userId], references: [id])
  approved              Boolean   @default(false) // 관리자 승인 필요
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([resortId])
  @@index([userId])
  @@map("rentals")
}

model Lesson {
  id                    String    @id @default(uuid())
  name                  String
  price                 Int
  duration              String
  level                 String    // 'beginner' | 'intermediate' | 'advanced'
  maxStudents           Int
  image                 String
  instructorCert        String?   // 강사 자격증 이미지 URL
  businessLicense       String?   // 사업자등록증 이미지 URL
  resortId              String
  resort                SkiResort @relation(fields: [resortId], references: [id], onDelete: Cascade)
  userId                String
  user                  User      @relation(fields: [userId], references: [id])
  approved              Boolean   @default(false) // 관리자 승인 필요
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([resortId])
  @@index([userId])
  @@map("lessons")
}

model Accommodation {
  id                    String    @id @default(uuid())
  name                  String
  type                  String    // 'hotel' | 'pension' | 'condo' | 'minbak'
  price                 Int
  originalPrice         Int?
  guests                String    // '2인', '4인', '6인'
  features              String    // 콤마 구분
  image                 String
  businessLicense       String?   // 사업자등록증 이미지 URL (필수)
  accommodationPermit   String?   // 숙박업 신고증 이미지 URL
  resortId              String
  resort                SkiResort @relation(fields: [resortId], references: [id], onDelete: Cascade)
  userId                String
  user                  User      @relation(fields: [userId], references: [id])
  approved              Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([resortId])
  @@index([userId])
  @@map("accommodations")
}

model BadgeRequest {
  id        String   @id @default(uuid())
  badgeType String   // 'level' | 'lv1' | 'lv2' | 'lv3' | 'demo' | 'teaching' | 'teaching1' | 'teaching2' | 'teaching3' | 'pro'
  image     String?  // 자격증 사진 URL
  status    String   @default("pending") // 'pending' | 'approved' | 'rejected'
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt]) // 관리자 승인 대기 목록
  @@index([userId])             // 내 뱃지 요청 조회
  @@map("badge_requests")
}

model ChatRoom {
  id              String    @id @default(uuid())
  user1Id         String
  user1           User      @relation("user1", fields: [user1Id], references: [id])
  user2Id         String
  user2           User      @relation("user2", fields: [user2Id], references: [id])
  user1LastReadAt DateTime?
  user2LastReadAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  messages        Message[]

  @@unique([user1Id, user2Id])
  @@map("chat_rooms")
}

model Message {
  id        String   @id @default(uuid())
  content   String
  imageUrl  String?  // 이미지/동영상 URL (Cloudinary)
  type      String   @default("text") // 'text' | 'price_offer'
  roomId    String
  room      ChatRoom @relation(fields: [roomId], references: [id])
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  createdAt DateTime @default(now())

  @@index([roomId])
  @@index([senderId])
  @@map("messages")
}

model Post {
  id        String    @id @default(uuid())
  title     String
  content   String
  category  String    // 'free' | 'review' | 'resort' | 'tip' | 'carpool' | 'poll'
  sport     String    // 'ski' | 'board'
  images    String?   // 콤마 구분 이미지 URLs
  likes     Int       @default(0)
  views     Int       @default(0)
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  comments  Comment[]
  postLikes PostLike[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([sport])
  @@index([category])
  @@index([userId])
  @@index([createdAt])
  @@map("posts")
}

model PostLike {
  id     String @id @default(uuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@map("post_likes")
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlists")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
  @@index([userId])
  @@map("comments")
}

model Notification {
  id        String   @id @default(uuid())
  type      String   // 'chat' | 'approve' | 'reject' | 'system' | 'badge'
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId, createdAt]) // /api/notifications 최신순 조회
  @@index([userId, read])      // 미읽음 카운트
  @@map("notifications")
}

model PhoneVerification {
  id        String   @id @default(uuid())
  phone     String
  code      String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("phone_verifications")
}

model EmailVerification {
  id        String   @id @default(uuid())
  email     String
  code      String
  purpose   String   @default("password_reset") // 'password_reset' | 'email_change' 등
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, code])
  @@map("email_verifications")
}

// 일일 방문 집계 — IP 단위로 하루 한 row, count 증가시켜 페이지뷰 누적.
// 관리자 통계 (DAU, 일별 방문자 추이, 페이지뷰) 의 데이터 소스.
model DailyVisit {
  id        String   @id @default(uuid())
  ip        String
  userId    String?  // 로그인한 유저면 기록
  date      String   // YYYY-MM-DD (KST 기준)
  count     Int      @default(1)
  firstSeen DateTime @default(now())
  lastSeen  DateTime @default(now())

  @@unique([ip, date])
  @@index([date])
  @@map("daily_visits")
}

model Review {
  id        String   @id @default(uuid())
  rating    Int      // 1-5
  content   String
  sellerId  String
  seller    User     @relation("reviewSeller", fields: [sellerId], references: [id])
  buyerId   String
  buyer     User     @relation("reviewBuyer", fields: [buyerId], references: [id])
  productId String?
  createdAt DateTime @default(now())

  @@index([sellerId])
  @@index([buyerId])
  @@map("reviews")
}

model Report {
  id          String   @id @default(uuid())
  type        String   // 'product' | 'post' | 'user'
  targetId    String
  reason      String
  description String?
  reporterId  String
  reporter    User     @relation(fields: [reporterId], references: [id])
  status      String   @default("pending") // 'pending' | 'resolved'
  createdAt   DateTime @default(now())

  @@index([reporterId])
  @@index([type, targetId])
  @@map("reports")
}

model Banner {
  id          String   @id @default(uuid())
  title       String
  description String
  tag         String
  url         String
  image       String?
  textColor   String?  // 글자 색상 hex (#ffffff)
  textAlign   String?  // 글자 위치 'left' | 'center' | 'right'
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("banners")
}

model AdSlotPricing {
  id            String   @id @default(uuid())
  slotType      String   // 'main_banner' | 'category' | 'premium'
  category      String   @default("none") // 'none' | 'used' | 'rental' | 'lesson' | 'accommodation'
  pricePerDay   Int      // 1일 가격 (원)
  maxConcurrent Int      @default(1) // 동시 광고 가능 수
  description   String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bookings AdBooking[]

  @@unique([slotType, category])
  @@map("ad_slot_pricings")
}

model AdBooking {
  id          String   @id @default(uuid())
  slotType    String   // 'main_banner' | 'category' | 'premium'
  category    String   @default("none") // 'none' | 'used' | 'rental' | 'lesson' | 'accommodation'
  title       String
  description String
  url         String
  image       String?
  textColor   String?  // 글자 색상 hex (#ffffff)
  textAlign   String?  // 글자 위치 'left' | 'center' | 'right'
  startDate   DateTime
  endDate     DateTime
  totalDays   Int
  totalPrice  Int
  status      String   @default("pending_payment")
  // 'pending_payment' | 'paid' | 'active' | 'completed' | 'cancelled' | 'refunded'
  adminNote   String?

  userId    String
  user      User          @relation(fields: [userId], references: [id])
  pricingId String
  pricing   AdSlotPricing @relation(fields: [pricingId], references: [id])
  payment   AdPayment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([slotType, startDate, endDate])
  @@index([startDate])
  @@index([endDate])
  @@map("ad_bookings")
}

model AdPayment {
  id           String    @id @default(uuid())
  bookingId    String    @unique
  booking      AdBooking @relation(fields: [bookingId], references: [id])
  paymentId    String    @unique // PortOne payment ID
  merchantUid  String    @unique // 주문번호
  payMethod    String    // 'card' | 'tosspay' | 'kakaopay' | 'naverpay'
  amount       Int
  status       String    @default("paid") // 'paid' | 'cancelled' | 'refunded'
  paidAt       DateTime
  receiptUrl   String?
  pgProvider   String?
  pgTid        String?
  cancelledAt  DateTime?
  cancelReason String?
  refundAmount Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ad_payments")
}

model AdRequest {
  id          String   @id @default(uuid())
  type        String   // 'main_banner' | 'category'
  category    String?  // 'used' | 'rental' | 'lesson' | 'accommodation' | null
  title       String
  description String
  url         String
  image       String?
  message     String?  // 광고주 추가 메모
  status      String   @default("pending") // 'pending' | 'approved' | 'rejected'
  adminNote   String?  // 거부 사유 등
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("ad_requests")
}

model SkiShop {
  id              String   @id @default(uuid())
  name            String
  area            String   // '강원' | '경기' | '서울' 등
  resort          String?  // 소속 스키장
  address         String
  description     String
  brands          String?  // 콤마 구분 브랜드
  phone           String?
  instagram       String?
  website         String?
  naverMap        String?
  hours           String?  // 영업시간
  image           String?  // 샵 대표 이미지
  businessLicense String   // 사업자등록증 이미지 (필수)
  approved        Boolean  @default(false)
  isPremium       Boolean  @default(false)
  premiumUntil    DateTime?
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([area])
  @@index([approved])
  @@map("ski_shops")
}

model RepairShop {
  id              String   @id @default(uuid())
  name            String
  area            String
  address         String
  description     String
  services        String?  // 콤마 구분 (튜닝, 왁싱, 바인딩, 엣지 등)
  phone           String?
  instagram       String?
  website         String?
  naverMap        String?
  hours           String?
  image           String?
  businessLicense String
  approved        Boolean  @default(false)
  isPremium       Boolean  @default(false)
  premiumUntil    DateTime?
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([area])
  @@index([approved])
  @@map("repair_shops")
}

// 위클리 다이제스트 이메일 구독 — 로그인 안 한 비회원도 구독 가능.
// 발송 cron 은 추후 구현, 지금은 수집만.
model NewsletterSubscription {
  id          String   @id @default(uuid())
  email       String   @unique
  source      String?  // 'home_footer' 등 가입 경로 추적
  unsubToken  String   @unique @default(uuid()) // 1-click unsubscribe
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([active])
  @@map("newsletter_subscriptions")
}
