generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev2.db"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  phone         String   @unique
  phoneVerified Boolean  @default(false)
  role          String   @default("user") // 'user' | 'admin'
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products Product[]
  rentals  Rental[]
  lessons  Lesson[]
  accommodations Accommodation[]
  badgeRequests  BadgeRequest[]
  chatRoomsAsUser1 ChatRoom[] @relation("user1")
  chatRoomsAsUser2 ChatRoom[] @relation("user2")
  messages         Message[]
  notifications    Notification[]

  @@map("users")
}

model SkiResort {
  id        String   @id @default(uuid())
  name      String
  location  String
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rentals        Rental[]
  lessons        Lesson[]
  accommodations Accommodation[]

  @@map("ski_resorts")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  brand       String
  price       Int
  image       String
  category    String   // 'new' | 'used'
  description String?
  rating      Float?
  reviewCount Int?
  condition   String?  // For used items: '상', '중', '하'
  usageCount  String?  // For used items
  userId      String?  // null for admin-crawled items, set for user-submitted
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("products")
}

model Rental {
  id         String    @id @default(uuid())
  name       String
  price      Int
  duration   String
  equipment  String
  image      String
  resortId   String
  resort     SkiResort @relation(fields: [resortId], references: [id])
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  approved   Boolean   @default(false) // 관리자 승인 필요
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("rentals")
}

model Lesson {
  id          String    @id @default(uuid())
  name        String
  price       Int
  duration    String
  level       String    // 'beginner' | 'intermediate' | 'advanced'
  maxStudents Int
  image       String
  resortId    String
  resort      SkiResort @relation(fields: [resortId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  approved    Boolean   @default(false) // 관리자 승인 필요
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("lessons")
}

model Accommodation {
  id            String    @id @default(uuid())
  name          String
  type          String    // 'hotel' | 'pension' | 'condo' | 'minbak'
  price         Int
  originalPrice Int?
  guests        String    // '2인', '4인', '6인'
  features      String    // 콤마 구분
  image         String
  resortId      String
  resort        SkiResort @relation(fields: [resortId], references: [id])
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  approved      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("accommodations")
}

model BadgeRequest {
  id        String   @id @default(uuid())
  badgeType String   // 'lv2' | 'lv3' | 'demo' | 'teaching' | 'pro'
  image     String?  // 자격증 사진 URL
  status    String   @default("pending") // 'pending' | 'approved' | 'rejected'
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("badge_requests")
}

model ChatRoom {
  id        String    @id @default(uuid())
  user1Id   String
  user1     User      @relation("user1", fields: [user1Id], references: [id])
  user2Id   String
  user2     User      @relation("user2", fields: [user2Id], references: [id])
  productId String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@unique([user1Id, user2Id, productId])
  @@map("chat_rooms")
}

model Message {
  id        String   @id @default(uuid())
  content   String
  roomId    String
  room      ChatRoom @relation(fields: [roomId], references: [id])
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  createdAt DateTime @default(now())

  @@map("messages")
}

model Notification {
  id        String   @id @default(uuid())
  type      String   // 'chat' | 'approve' | 'reject' | 'system' | 'badge'
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@map("notifications")
}

model PhoneVerification {
  id        String   @id @default(uuid())
  phone     String
  code      String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("phone_verifications")
}
